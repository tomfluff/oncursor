# Copy to .env for local dev (never commit the real key).
# In production these are set as Cloud Run env vars / secrets.

# Required: your OpenAI API key.
OPENAI_API_KEY=sk-...

# Optional: vision model to use.
OPENAI_MODEL=gpt-4.1

# Optional: comma-separated CORS allowlist (the demo's origin).
# Use "*" only for local testing.
ALLOWED_ORIGINS=https://tomfluff.github.io

# Optional: max accepted image size in bytes (default 8 MB).
# MAX_IMAGE_BYTES=8388608
